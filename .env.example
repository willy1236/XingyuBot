# App environment selector: development | testing | production
APP_ENV=development
BOT_CODE=1

# Runtime toggles
LOG_LEVEL=INFO
API_WEBSITE=false
FILE_LOG=false
MONGODB_CONNECTION=false
TWITCH_BOT=false
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_DEBUG=false
SENTRY_SEND_DEFAULT_PII=false
SENTRY_TRACES_SAMPLE_RATE=0.0

# Deployment settings
TASK_REPORT=1001882729715085462
FEEDBACK_CHANNEL=902209434867073034
ERROR_REPORT=870929381621661697
REPORT_CHANNEL=876480208092422204
DM_CHANNEL=956523514389733408
MENTIONED_CHANNEL=999344358560120853
MENTION_EVERYONE_CHANNEL=999346052857606194
VIP_ADMIN_CHANNEL=1427543821977128960
HAPPYCAMP_GUILD=[566533708371329024]
DEBUG_GUILDS=[566533708371329024]
DEBUG_MODE=true

# Required SQL connection settings (fail-fast)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=replace_with_database_password
DB_NAME=stardb

# Required secrets (fail-fast)
MC_SERVER_HOST=127.0.0.1
MC_SERVER_PORT=25575
MC_SERVER_PASSWORD=replace_with_mc_rcon_password

# Required app settings
ZEROTIER_NETWORK_ID=replace_with_zerotier_network_id
BASE_DOMAIN=localhost
BASE_WWW_URL=http://localhost:3000

JWT_SECRET=replace_with_jwt_secret
NOTION_DATABASE_ID=replace_with_notion_database_id
