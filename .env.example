# App environment selector: development | testing | production
APP_ENV=development

# Required SQL connection settings (fail-fast)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=replace_with_database_password
DB_NAME=stardb

# Required secrets (fail-fast)
MC_SERVER_HOST=127.0.0.1
MC_SERVER_PORT=25575
MC_SERVER_PASSWORD=replace_with_mc_rcon_password

JWT_SECRET=replace_with_jwt_secret
