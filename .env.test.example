# Test environment variables template
# Copy to .env.test for local test runs

# Database settings (test only)
DATABASE_URL=postgresql://test:test@localhost:5432/xingyu_test

# Logging
LOG_LEVEL=DEBUG


# Other settings
TESTING=true
DEBUG=true

# Required secrets for fail-fast startup checks
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=test_db_password
DB_NAME=xingyu_test
MC_SERVER_PASSWORD=test_mc_rcon_password
MC_SERVER_HOST=localhost
MC_SERVER_PORT=25575
JWT_SECRET=test_jwt_secret
