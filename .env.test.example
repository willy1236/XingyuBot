# Test environment variables template
# Copy to .env.test for local test runs

APP_ENV=testing
BOT_CODE=1

# Database settings (test only)
DATABASE_URL=postgresql://test:test@localhost:5432/xingyu_test

# Logging
LOG_LEVEL=DEBUG

# Runtime toggles
API_WEBSITE=false
FILE_LOG=false
MONGODB_CONNECTION=false
TWITCH_BOT=false
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=testing
SENTRY_RELEASE=
SENTRY_DEBUG=false
SENTRY_SEND_DEFAULT_PII=false
SENTRY_TRACES_SAMPLE_RATE=0.0

# Deployment settings
TASK_REPORT=1001882729715085462
FEEDBACK_CHANNEL=902209434867073034
ERROR_REPORT=870929381621661697
REPORT_CHANNEL=876480208092422204
DM_CHANNEL=956523514389733408
MENTIONED_CHANNEL=999344358560120853
MENTION_EVERYONE_CHANNEL=999346052857606194
VIP_ADMIN_CHANNEL=1427543821977128960
HAPPYCAMP_GUILD=[566533708371329024]
DEBUG_GUILDS=[566533708371329024]
