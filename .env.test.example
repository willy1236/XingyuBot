# Test environment variables template
# Copy to .env.test for local test runs

# Database settings (test only)
DATABASE_URL=postgresql://test:test@localhost:5432/xingyu_test

# Logging
LOG_LEVEL=DEBUG

# API keys/tokens (use fake values in tests)
DISCORD_TOKEN=test_token_discord
TWITCH_TOKEN=test_token_twitch
GOOGLE_API_KEY=test_google_api_key

# Other settings
TESTING=true
DEBUG=true
